## Interview App environment variables (TEMPLATE only)
## This file is committed to git. It documents which variables the app needs.
## To run the app: copy this to `.env` in the same folder, then put your real API key in `.env`.
## The `.env` file is gitignored so your secrets are never committed.

# OpenAI (no space after =)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

# App
APP_ENV=dev
# Optional: directory for saved mock session JSON (default: data/sessions relative to cwd)
# SESSIONS_DIR=data/sessions

# Security (optional; defaults are safe for local dev)
# SECURITY_MAX_INPUT_LENGTH=8000
# SECURITY_PROMPT_INJECTION_STRICT=false
# SECURITY_RATE_LIMIT_MAX_REQUESTS=20
# SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
